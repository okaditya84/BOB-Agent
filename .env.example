# ============================================================================
# BOBAI — environment template. Copy to .env and fill in. NEVER commit .env.
# ============================================================================

# ---- LLM providers (used by llm-rotate; any subset can be set) -------------
# The model/provider is fully env-driven — change these without touching code.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# Default model the assistant/agent uses (provider:model form resolved by llm-rotate config)
BOBAI_DEFAULT_PROVIDER=openrouter
BOBAI_DEFAULT_MODEL=openai/gpt-4o-mini

# ---- Web search (assistant tools) ------------------------------------------
TAVILY_API_KEY=
SERPER_API_KEY=

# ---- Identity Trust engine -------------------------------------------------
# Risk thresholds (0..1). score >= deny -> block; >= step_up -> challenge; else allow.
IDTRUST_THRESHOLD_STEP_UP=0.45
IDTRUST_THRESHOLD_DENY=0.85
# Impossible-travel: implied speed (km/h) above which travel is physically implausible.
IDTRUST_IMPOSSIBLE_TRAVEL_KMH=900
# SQLite path for risk events + audit log.
IDTRUST_DB_PATH=./data/identity_trust.db
# Secret used to HMAC-tokenize PII and seed the audit hash chain. CHANGE THIS.
IDTRUST_SECRET=change-me-to-a-long-random-string

# ---- WebAuthn / passkey step-up --------------------------------------------
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=BOBAI
WEBAUTHN_ORIGIN=http://localhost:5173

# ---- IP geolocation (optional enrichment; browser geolocation is primary) --
# Path to a GeoLite2 / DB-IP Lite .mmdb file. If unset, IP enrichment is skipped.
GEOIP_MMDB_PATH=
